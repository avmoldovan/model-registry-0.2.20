	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set default content-type for POST/PATCH requests",
					"if (pm.request.method === 'POST' || pm.request.method === 'PATCH') {",
					"    if (!pm.request.headers.has('Content-Type')) {",
					"        pm.request.headers.add({",
					"            key: 'Content-Type',",
					"            value: 'application/json'",
					"        });",
					"    }",
					"}",
					"",
					"// Add timestamp to requests for tracking",
					"pm.request.headers.add({",
					"    key: 'X-Request-Timestamp',",
					"    value: new Date().toISOString()",
					"});"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Basic response validation",
					"pm.test('Response status code is successful', function () {",
					"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
					"});",
					"",
					"// Check response time",
					"pm.test('Response time is less than 5000ms', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});",
					"",
					"// Validate JSON response for GET requests",
					"if (pm.request.method === 'GET' && pm.response.headers.get('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) {",
					"    pm.test('Response is valid JSON', function () {",
					"        pm.expect(pm.response.json()).to.be.an('object');",
					"    });",
					"}"
				]
			}
		}
